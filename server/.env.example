# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ── Google Cloud ─────────────────────────────────────────────────────────────
GCP_PROJECT_ID=patman-inventory

# For local dev: point to a service-account JSON key file.
# On Cloud Run: leave unset — ADC uses the attached service account automatically.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Production: your GitHub Pages URL.
# Local dev: add http://localhost:PORT as needed.
CORS_ORIGIN=https://mughalfaizan0034-dotcom.github.io,http://localhost:3000
