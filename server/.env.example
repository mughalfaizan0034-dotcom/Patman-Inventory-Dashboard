# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ── Google Cloud ─────────────────────────────────────────────────────────────
GCP_PROJECT_ID=patman-inventory

# For local dev: point to a service-account JSON key file.
# On Cloud Run: leave unset — ADC uses the attached service account automatically.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Production: your GitHub Pages URL.
# Local dev: add http://localhost:PORT as needed.
CORS_ORIGIN=https://mughalfaizan0034-dotcom.github.io,http://localhost:3000

# ── Cloud Tasks (Phase A async upload lifecycle, 2026-05-18) ─────────────────
# All four must be set for Cloud Tasks to be active. When any is missing,
# cloudTasksService runs the summary refresh inline as a fallback (same
# correctness, just no out-of-band scheduling). Set up the queue via:
#
#   gcloud tasks queues create patman-summary-refresh \
#     --location=us-central1
#
# Grant the Cloud Run SA enqueue permission:
#
#   gcloud tasks queues add-iam-policy-binding patman-summary-refresh \
#     --location=us-central1 \
#     --member=serviceAccount:<runtime-sa>@<project>.iam.gserviceaccount.com \
#     --role=roles/cloudtasks.enqueuer
#
# Grant the invoker SA permission to call this Cloud Run service:
#
#   gcloud run services add-iam-policy-binding patman-inventory-api \
#     --region=us-central1 \
#     --member=serviceAccount:<invoker-sa>@<project>.iam.gserviceaccount.com \
#     --role=roles/run.invoker
#
# Then set the env vars on Cloud Run and redeploy.
TASKS_LOCATION=us-central1
TASKS_QUEUE_NAME=patman-summary-refresh
WORKER_BASE_URL=https://patman-inventory-api-471065748321.us-central1.run.app
TASKS_INVOKER_SA=patman-tasks-invoker@patman-inventory.iam.gserviceaccount.com
